  {
    "name": "Retrieve all users successfully",
    "category": "functional",
    "description": "Validates that the API returns all users with a 200 status code and the expected structure.",
    "input": {
      "method": "GET",
      "endpoint": "/users",
      "payload": null,
      "headers": {}
    },
    "expected_result": {
      "status_code": 200,
      "contains_key": "users",
      "contains_value": null,
      "max_response_time_ms": 2000,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_schema": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "role": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "name",
                "email",
                "role"
              ]
            }
          },
          "count": {
            "type": "integer",
            "enum": [
              3
            ]
          }
        },
        "required": [
          "users",
          "count"
        ]
      }
    }
  },
