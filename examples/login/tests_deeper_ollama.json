[
  {
    "name": "Valid credentials",
    "category": "functional",
    "description": "Happy path with valid admin credentials",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": {
        "email": "admin@example.com",
        "password": "admin123"
      },
      "headers": {}
    },
    "expected_result": {
      "status_code": 200,
      "contains_key": "token",
      "contains_value": null,
      "max_response_time_ms": 2000,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_schema": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "email": {
            "type": "string"
          }
        },
        "required": [
          "token",
          "email"
        ]
      }
    }
  },
