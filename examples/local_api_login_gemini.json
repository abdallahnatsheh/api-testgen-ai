[
  {
    "name": "Successful login with valid credentials",
    "category": "functional",
    "description": "Should return a 200 status code and a token upon successful authentication.",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": {
        "email": "admin@example.com",
        "password": "admin123"
      },
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 200,
      "contains_key": "token"
    }
  },
  {
    "name": "Login with incorrect password",
    "category": "negative",
    "description": "Should return a 401 status code for incorrect password.",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": {
        "email": "admin@example.com",
        "password": "wrongpass"
      },
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 401,
      "contains_key": "detail"
    }
  },
  {
    "name": "Login with non-existent email",
    "category": "negative",
    "description": "Should return a 404 status code for an email that does not exist in the system.",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": {
        "email": "nonexistent@example.com",
        "password": "anypassword"
      },
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 404,
      "contains_key": "detail"
    }
  },
  {
    "name": "Login with missing email field",
    "category": "validation",
    "description": "Should return a 422 status code when the email field is entirely missing from the payload.",
