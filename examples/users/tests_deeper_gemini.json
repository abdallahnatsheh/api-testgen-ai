      "method": "POST",
      "endpoint": "/users",
      "payload": {
        "name": "New User",
        "email": "new@example.com",
        "role": "user"
      },
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 405,
      "contains_key": "detail",
      "contains_value": {
        "detail": "Method Not Allowed"
      },
      "max_response_time_ms": 2000,
      "response_headers": null,
      "response_schema": null
    }
  },
