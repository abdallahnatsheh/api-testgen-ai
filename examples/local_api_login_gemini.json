      "method": "POST",
      "endpoint": "/login",
      "payload": {
        "password": "admin123"
      },
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 422,
      "contains_key": "detail"
    }
  },
  {
    "name": "Login with missing password field",
    "category": "validation",
    "description": "Should return a 422 status code when the password field is entirely missing from the payload.",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": {
        "email": "admin@example.com"
      },
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 422,
      "contains_key": "detail"
    }
  },
  {
    "name": "Login with invalid email format",
    "category": "validation",
    "description": "Should return 404 — API does not validate format, looks up email directly.",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": {
        "email": "invalid-email-format",
        "password": "admin123"
      },
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 404,
      "contains_key": "detail"
    }
  },
  {
    "name": "Login with empty payload",
    "category": "edge_case",
