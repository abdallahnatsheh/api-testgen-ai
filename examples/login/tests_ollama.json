[
  {
    "name": "Valid credentials - admin@example.com",
    "category": "functional",
    "description": "Should return a JWT token for valid admin credentials",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": { "email": "admin@example.com", "password": "admin123" },
      "headers": {}
    },
    "expected_result": {
      "status_code": 200,
      "contains_key": "token",
      "contains_value": null
    }
  },
  {
    "name": "Valid credentials - user@example.com",
    "category": "functional",
    "description": "Should return a JWT token for valid user credentials",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": { "email": "user@example.com", "password": "user123" },
      "headers": {}
    },
    "expected_result": {
      "status_code": 200,
      "contains_key": "token",
      "contains_value": null
    }
  },
  {
    "name": "Wrong password",
    "category": "negative",
    "description": "Should return a 401 error for wrong password",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": { "email": "admin@example.com", "password": "wrong_password" },
      "headers": {}
    },
    "expected_result": {
      "status_code": 401,
      "contains_key": "detail",
      "contains_value": { "detail": "Invalid password" }
    }
  },
  {
    "name": "Unknown email",
    "category": "negative",
    "description": "Should return a 404 error for unknown email",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": { "email": "unknown@example.com", "password": "admin123" },
      "headers": {}
    },
    "expected_result": {
      "status_code": 404,
      "contains_key": "detail",
      "contains_value": { "detail": "User not found" }
    }
  },
  {
    "name": "Locked account",
    "category": "negative",
    "description": "Should return a 403 error for locked account — currently a known bug (returns 200)",
    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": { "email": "locked@example.com", "password": "locked123" },
      "headers": {}
    },
    "expected_result": {
      "status_code": 403,
      "contains_key": "detail",
      "contains_value": { "detail": "Account is locked" }
    }
  },
  {
