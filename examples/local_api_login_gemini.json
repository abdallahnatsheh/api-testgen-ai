    "input": {
      "method": "POST",
      "endpoint": "/login",
      "payload": {},
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "expected_result": {
      "status_code": 422,
      "contains_key": "detail"
    }
  },
  {
    "name": "Login with empty email string",
