    "description": "Checks that the 'users' array contains exactly 3 items, each with 'id', 'name', and 'email' fields.",
    "input": {
      "method": "GET",
      "endpoint": "/users",
      "payload": null,
      "headers": {}
    },
    "expected_result": {
      "status_code": 200,
      "contains_key": "users",
      "contains_value": null,
      "max_response_time_ms": 2000,
      "response_headers": {
        "Content-Type": "application/json"
      },
      "response_schema": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "integer"
                },
                "name": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "name",
                "email"
              ]
            }
          },
          "count": {
            "type": "integer",
            "enum": [
              3
            ]
          }
        },
        "required": [
          "users",
          "count"
        ]
      }
    }
